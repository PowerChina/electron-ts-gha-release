{
  "name": "electron-ts-gha-release",
  "version": "0.1.0",
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf dist release",
    "build": "npm run clean && tsc",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "release": "npm run dist",
    "dist:win": "npm run build && electron-builder --win nsis",
    "verify:exe": "npm run dist:win && ls release/*.exe"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Electron + TypeScript + GitHub Actions release template",
  "dependencies": {
    "electron": "^41.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.lihua.electronts",
    "productName": "ElectronTSApp",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "index.html"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
