{
  "name": "world-time-board",
  "version": "0.1.0",
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf dist release",
    "build": "npm run clean && tsc",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "release": "npm run dist",
    "dist:win": "npm run build && electron-builder --publish never --win nsis",
    "dist:mac": "npm run build && electron-builder --publish never --mac dmg zip --x64",
    "dist:linux": "npm run build && electron-builder --publish never --linux AppImage",
    "verify:exe": "npm run dist:win && ls release/*.exe",
    "test:e2e": "npm run build && playwright test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "World Time Board desktop app",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "playwright": "^1.54.2",
    "@playwright/test": "^1.54.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.lihua.worldtimeboard",
    "productName": "World Time Board",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "index.html"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
